<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5494049082029237"
        crossorigin="anonymous"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>016 Empregos Franca</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

    <!-- MENU MOBILE -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const menuBtn = document.getElementById("menu-btn");
            const closeBtn = document.getElementById("close-menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");

            if (menuBtn) {
                menuBtn.addEventListener("click", () => {
                    mobileMenu.classList.remove("hidden");
                });
            }

            if (closeBtn) {
                closeBtn.addEventListener("click", () => {
                    mobileMenu.classList.add("hidden");
                });
            }
        });
    </script>
</head>

<body class="bg-gray-50 text-gray-800 flex flex-col min-h-screen">

    <!-- HEADER -->
    <header class="bg-white shadow-md w-full">
        <div class="container mx-auto flex justify-between items-center p-4">
            <div class="flex items-center space-x-3">
                <img src="/016empregos.jpg" alt="Logo" class="w-10 h-10">
                <div>
                    <h1 class="text-lg font-bold text-gray-800">016 Empregos Franca</h1>
                    <p class="text-sm text-gray-500">Conectando talentos e oportunidades</p>
                </div>
            </div>

            <!-- Desktop -->
            <div class="hidden md:flex items-center space-x-3">
                <a href="/planos.html"
                    class="bg-green-500 text-white px-4 py-2 rounded-lg font-medium hover:bg-green-600">Anunciar</a>
                <a href="https://chat.whatsapp.com/FejC0MSgfOt6FlH9RSLVCs"
                    class="bg-green-100 text-green-700 px-4 py-2 rounded-lg font-medium hover:bg-green-200">
                    Entrar no Grupo
                </a>
            </div>

            <!-- Mobile -->
            <button id="menu-btn" class="md:hidden text-gray-700 focus:outline-none">
                ☰
            </button>
        </div>
    </header>

    <!-- MOBILE MENU -->
    <div id="mobile-menu"
        class="hidden md:hidden fixed top-0 left-0 w-full h-full bg-white z-50 overflow-y-auto">
        <div class="p-4 space-y-4">

            <button id="close-menu-btn" class="float-right text-gray-700">
                ✕
            </button>

            <div class="pt-8 flex flex-col space-y-3 border-b pb-4">
                <a href="/planos.html"
                    class="bg-green-500 text-white px-4 py-2 rounded-lg font-medium">Anunciar</a>
                <a href="https://chat.whatsapp.com/FejC0MSgfOt6FlH9RSLVCs"
                    class="bg-green-100 text-green-700 px-4 py-2 rounded-lg font-medium">
                    Entrar no Grupo
                </a>
            </div>

            <!-- FILTRO MOBILE -->
            <div class="mt-4">
                <h2 class="text-lg font-semibold text-gray-700 mb-3">🔍 Filtrar por cargo</h2>
                <div class="max-h-64 overflow-y-auto border rounded-lg p-3 bg-gray-50">
                    <% const cargosUnicos=[...new Set(jobs.map(j=> j.title.trim()))]; %>
                        <% cargosUnicos.forEach(cargo=> { %>
                            <label class="flex items-center space-x-2 py-1">
                                <input type="checkbox" value="<%= cargo %>" class="cargo-checkbox">
                                <span><%= cargo %></span>
                            </label>
                        <% }) %>
                </div>
            </div>

        </div>
    </div>

    <!-- HERO -->
    <section class="bg-gradient-to-r from-blue-600 to-blue-500 text-white py-10 text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-2">
            Vagas em Franca — encontre sua próxima oportunidade
        </h2>

        <div class="flex justify-center">
            <input type="text" id="search-input"
                placeholder="Ex: Atendente, auxiliar de produção, vendedor"
                class="w-3/4 md:w-1/3 px-4 py-2 rounded-l-lg text-gray-700 focus:outline-none">

            <button id="clear-btn"
                class="bg-blue-700 px-4 py-2 rounded-r-lg hover:bg-blue-800">
                Limpar
            </button>
        </div>
    </section>

    <main class="container mx-auto flex flex-col md:flex-row gap-6 p-4 flex-grow">

        <!-- SIDEBAR DESKTOP -->
        <aside class="hidden md:block md:w-1/4 bg-white rounded-2xl shadow-md p-4 h-fit">
            <h2 class="text-lg font-semibold text-gray-700 mb-3">🔍 Filtrar por cargo</h2>
            <div class="max-h-80 overflow-y-auto border rounded-lg p-3 bg-gray-50">
                <% cargosUnicos.forEach(cargo=> { %>
                    <label class="flex items-center space-x-2 py-1">
                        <input type="checkbox" value="<%= cargo %>" class="cargo-checkbox">
                        <span><%= cargo %></span>
                    </label>
                <% }) %>
            </div>
        </aside>

        <!-- VAGAS -->
        <section id="jobs-container"
            class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-4">

            <% jobs.forEach(job=> { %>

                <div class="job-card bg-white p-5 rounded-2xl shadow-md hover:shadow-lg transition">

                    <h3 class="text-lg font-semibold text-blue-700 mb-2">
                        <%= job.title %>
                    </h3>

                    <p class="text-gray-700 mb-3">
                        <%- job.description %>
                    </p>

                    <% if (job.email || job.phone) { %>
                        <div class="flex flex-wrap gap-3 mb-3">
                            <% if (job.email) { %>
                                <a href="mailto:<%= job.email %>"
                                    class="bg-blue-100 text-blue-700 font-bold px-3 py-1 rounded-lg hover:bg-blue-200 break-all">
                                    📧 <%= job.email %>
                                </a>
                            <% } %>

                            <% if (job.phone) { %>
                                <a href="https://wa.me/<%= job.phone.replace(/\D/g, '') %>"
                                   target="_blank"
                                   class="bg-green-100 text-green-700 font-bold px-3 py-1 rounded-lg hover:bg-green-200 break-all">
                                    📱 <%= job.phone %>
                                </a>
                            <% } %>
                        </div>
                    <% } %>

                   

                    <button
                        class="bg-blue-600 text-white px-3 py-1 rounded-lg hover:bg-blue-700 text-sm"
                        onclick="shareJob('<%= job.title %>')">
                        Compartilhar
                    </button>

                </div>

            <% }) %>

        </section>

    </main>

<script>

    // ===============================
    // 🔥 COMPARTILHAR
    // ===============================
    function shareJob(title) {
        const url = window.location.origin + "/?search=" + encodeURIComponent(title);

        if (navigator.share) {
            navigator.share({
                title: "Vaga de Emprego",
                text: "Confira essa vaga: " + title,
                url: url
            });
        } else {
            navigator.clipboard.writeText(url);
            alert("Link copiado!");
        }
    }

    const checkboxes = document.querySelectorAll('.cargo-checkbox');
    const cards = document.querySelectorAll('.job-card');
    const searchInput = document.getElementById('search-input');

    function filterCards() {

        const searchTerm = searchInput.value.toLowerCase();
        const ativos = Array.from(checkboxes)
            .filter(cb => cb.checked)
            .map(cb => cb.value);

        cards.forEach(card => {

            const titulo = card.querySelector('h3').innerText;
            const descricao = card.querySelector('p').innerText;

            const matchSearch =
                titulo.toLowerCase().includes(searchTerm) ||
                descricao.toLowerCase().includes(searchTerm);

            const matchCheckbox =
                ativos.length === 0 || ativos.includes(titulo);

            card.style.display =
                matchSearch && matchCheckbox ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', filterCards);
    checkboxes.forEach(cb => cb.addEventListener('change', filterCards));

    document.getElementById('clear-btn').addEventListener('click', () => {
        searchInput.value = '';
        checkboxes.forEach(cb => cb.checked = false);
        filterCards();
    });

    // ===============================
    // 🚀 AUTO PESQUISA VIA LINK
    // ===============================
    window.addEventListener("DOMContentLoaded", () => {
        const params = new URLSearchParams(window.location.search);
        const searchValue = params.get("search");

        if (searchValue) {
            searchInput.value = searchValue;
            filterCards();
        }
    });

</script>

</body>
</html>